class Main {
    function main() {
        
        Platform p = Platform.new()
        Ball b = Ball.new()

        while (b.getX() > 0) {

            bool moveDown = Keyboard.isDown()
            bool moveUp = Keyboard.isUp()
            p.move(moveDown, moveUp)

            b.move(p)

            p.render()

            b.render()
        }
    }
}